---
import { serviceBlocksData } from '@utils/service-blocks';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const blockData = serviceBlocksData[slug];

if (!blockData) return null;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16 mt-8">
  {/* Kutucuk 1: Belirtiler */}
  <div class="bg-amber-500/5 border border-amber-500/20 rounded-2xl p-6 hover:bg-amber-500/10 transition-colors shadow-lg shadow-amber-900/10">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-full bg-amber-500/20 flex items-center justify-center text-amber-500">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
        </svg>
      </div>
      <h3 class="font-display font-bold text-amber-500 uppercase tracking-widest text-sm">Belirtiler</h3>
    </div>
    <ul class="space-y-2 text-sm text-slate-300">
      {blockData.symptoms.map(symptom => (
        <li class="flex items-start gap-2">
          <span class="text-amber-500 mt-1">•</span>
          <span>{symptom}</span>
        </li>
      ))}
    </ul>
  </div>

  {/* Kutucuk 2: Gecikme Riskleri */}
  <div class="bg-rose-500/5 border border-rose-500/20 rounded-2xl p-6 hover:bg-rose-500/10 transition-colors shadow-lg shadow-rose-900/10">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-full bg-rose-500/20 flex items-center justify-center text-rose-500">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
      </div>
      <h3 class="font-display font-bold text-rose-500 uppercase tracking-widest text-sm">Gecikme Riskleri</h3>
    </div>
    <ul class="space-y-2 text-sm text-slate-300">
      {blockData.risks.map(risk => (
        <li class="flex items-start gap-2">
          <span class="text-rose-500 mt-1">•</span>
          <span>{risk}</span>
        </li>
      ))}
    </ul>
  </div>

  {/* Kutucuk 3: Çözüm Süresi */}
  <div class="bg-blue-500/5 border border-blue-500/20 rounded-2xl p-6 hover:bg-blue-500/10 transition-colors shadow-lg shadow-blue-900/10">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-full bg-blue-500/20 flex items-center justify-center text-blue-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
      </div>
      <h3 class="font-display font-bold text-blue-400 uppercase tracking-widest text-sm">Çözüm Süresi</h3>
    </div>
    <div class="text-lg font-bold text-white mb-2 leading-tight">
      {blockData.duration.split('\n')[0]}
    </div>
    <p class="text-sm text-slate-400">
      {blockData.duration.split('\n').slice(1).join('\n')}
    </p>
  </div>

  {/* Kutucuk 4: Parça Seçeneği */}
  <div class="bg-emerald-500/5 border border-emerald-500/20 rounded-2xl p-6 hover:bg-emerald-500/10 transition-colors shadow-lg shadow-emerald-900/10">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-full bg-emerald-500/20 flex items-center justify-center text-emerald-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
      </div>
      <h3 class="font-display font-bold text-emerald-400 uppercase tracking-widest text-sm">Parça Seçeneği</h3>
    </div>
    <div class="text-lg font-bold text-white mb-2 leading-tight">
      {blockData.partType.split('\n')[0]}
    </div>
    <p class="text-sm text-slate-400">
      {blockData.partType.split('\n').slice(1).join('\n')}
    </p>
  </div>
</div>
