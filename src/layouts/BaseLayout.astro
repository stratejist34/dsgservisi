---
import Header from "@components/common/Header.astro";
import Footer from "@components/common/Footer.astro";
import LazyFloatingWidgets from "@components/common/LazyFloatingWidgets";
import { buildBusinessNode, buildWebSite } from "@/lib/schema";
import { SITE_CONFIG as LEGACY_SITE_CONFIG } from "@utils/constants";
import "@styles/global.css";
import "@styles/reveal.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  image = "/images/og-image.webp",
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const rootSchema = {
  "@context": "https://schema.org",
  "@graph": [buildWebSite(), buildBusinessNode()],
};

// Sayfa kimliğini belirle (gtag etkinlikleri için)
const path = Astro.url.pathname;
let pageId = "diger_sayfalar";
if (path === "/") pageId = "anasayfa";
else if (path.includes("/iletisim")) pageId = "iletisim_sayfasi";
else if (path.includes("/hizmetler")) pageId = "hizmetler_sayfasi";
else if (path.includes("/blog")) pageId = "blog_sayfasi";
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* Resource Hints - EN ÜSTTE, meta tag'lerden ÖNCE */}
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <link rel="icon" type="image/webp" href="/images/icon.webp" />
    <link rel="icon" type="image/png" href="/images/icon.png" />
    <link rel="canonical" href={canonicalURL} />

    {/* SEO Meta Tags */}
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="robots" content="max-image-preview:large" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />



    {/* Critical CSS - Genişletilmiş */}
    <style is:inline>
      /* Above-the-fold critical styles */
      body {
        font-family:
          "Inter",
          system-ui,
          -apple-system,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
        background-color: #ffffff;
        color: #1a202c;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        overflow-x: hidden;
        width: 100%;
        min-width: 320px;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 80px;
      }
      .container {
        margin-left: auto;
        margin-right: auto;
        padding-left: 1rem;
        padding-right: 1rem;
        max-width: 1280px;
        width: 100%;
      }
      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-family:
          "Oswald",
          system-ui,
          -apple-system,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
        font-weight: 600;
        margin: 0;
      }
      h1 {
        font-size: 1.875rem;
        line-height: 2.25rem;
        font-weight: 600;
      }
      @media (min-width: 768px) {
        .container {
          padding-left: 1.5rem;
          padding-right: 1.5rem;
        }
        h1 {
          font-size: 2.25rem;
          line-height: 2.5rem;
        }
      }
      @media (min-width: 1024px) {
        .container {
          padding-left: 2rem;
          padding-right: 2rem;
        }
        h1 {
          font-size: 2.25rem;
          line-height: 2.5rem;
        }
      }
      /* Prevent layout shift */
      img {
        max-width: 100%;
        height: auto;
        display: block;
      }
      /* Hero section critical styles */
      section {
        position: relative;
      }
    </style>

    {/* Optimize edilmiş Scroll ve Reveal Sistemi */}
    <style is:global>
      /* 1. Smooth scroll */
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 80px;
      }

      /* 2. Reveal (klasik fade-up) */
      [data-reveal] {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
          transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .reveal--in {
        opacity: 1;
        transform: translateY(0);
      }

      /* 2b. Animate (fade-up) */
      [data-animate] {
        opacity: 0;
        transform: translateY(30px);
        transition:
          opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
          transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      }
      [data-animate].animate-in {
        opacity: 1;
        transform: translateY(0);
      }

      /* CTA butonları için özel easing */
      [data-animate].cta-ease-fast {
        transition: all 0.7s cubic-bezier(0.22, 1, 0.36, 1);
      }
      [data-animate].cta-ease-soft {
        transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }

      /* DSG Rozeti - yukarıdan yumuşak iniş ve hafif parlama */
      @keyframes badge-drop {
        0% {
          opacity: 0;
          transform: translateY(-16px) scale(0.98);
        }
        70% {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
        100% {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }
      [data-badge].animate-in {
        animation: badge-drop 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      [data-badge].animate-in .premium-shine::before {
        transition-duration: 1400ms;
      }

      /* Marka logoları - masaüstünde karşılıklı akış */
      @keyframes slide-ltr {
        from {
          opacity: 0;
          transform: translateX(-26px);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }
      @keyframes slide-rtl {
        from {
          opacity: 0;
          transform: translateX(26px);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }
      /* Varsayılan reveal'ı geçersiz kıl (logolar için X ekseni) */
      [data-reveal][data-dir] {
        opacity: 0;
        transform: translateX(18px);
        transition: none;
      }
      [data-reveal][data-dir="ltr"].animate-in {
        animation: slide-ltr 1.3s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      [data-reveal][data-dir="rtl"].animate-in {
        animation: slide-rtl 1.3s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      @media (max-width: 1023px) {
        [data-reveal][data-dir] {
          opacity: 1;
          transform: none;
          animation: none !important;
        }
      }

      /* 3. Header - SADECE navigation header (site header), article header'ları DEĞİL */
      body > header:not(.blog-article-header),
      body > main > header:not(.blog-article-header) {
        /* Header component zaten fixed, burada sadece geçiş efekti */
      }

      /* Article header'ları KESINLIKLE sticky olmasın */
      article header.blog-article-header {
        position: static !important;
        top: auto !important;
      }

      /* 4. Progress bar */
      .scroll-progress {
        position: fixed;
        top: 0;
        height: 3px;
        background: linear-gradient(90deg, cyan, blue);
        transition: width 0.1s ease;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        [data-reveal],
        [data-animate] {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }
    </style>

    {/* Google Search Console Verification */}
    {
      import.meta.env.PUBLIC_GSC_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={import.meta.env.PUBLIC_GSC_VERIFICATION}
        />
      )
    }

    <script type="application/ld+json" set:html={JSON.stringify(rootSchema)} />
    <slot name="head" />
  </head>
  <body class="smooth-scroll">
    <Header />

    <main
      class="pt-20"
      style="position: relative; overflow: visible; contain: none;"
    >
      <slot />
    </main>

    <Footer />

    {/* Floating Buttons - Optimize lazy loading */}
    {
      /*
         NUCLEAR PERFORMANCE OPTIMIZATION:
         Floating Buttons are entirely removed from Astro's critical hydration path.
         They are managed by LazyFloatingWidgets which only triggers after LCP is complete.
      */
    }
    <LazyFloatingWidgets
      client:idle
      pageId={pageId}
      phone={LEGACY_SITE_CONFIG.phone}
      title={title}
      canonicalURL={canonicalURL.toString()}
    />

    <script is:inline>
      (function () {
        let loaded = false;
        function triggerWidgets() {
          if (loaded) return;
          loaded = true;
          window.dispatchEvent(new CustomEvent("load-floating-widgets"));
        }

        ["touchstart", "mousedown", "scroll", "keydown"].forEach((e) => {
          window.addEventListener(e, triggerWidgets, {
            once: true,
            passive: true,
          });
        });
        setTimeout(triggerWidgets, 6000);
      })();
    </script>

    <div id="global-call-modal" class="call-modal hidden" inert>
      <div class="call-modal__backdrop" data-close-modal></div>
      <div
        class="call-modal__dialog"
        role="dialog"
        aria-modal="true"
        tabindex="-1"
      >
        <button
          class="call-modal__close"
          type="button"
          aria-label="Kapat"
          data-close-modal
          tabindex="-1">&times;</button
        >
        <p class="call-modal__tag">SERVİS BÖLGESİ KONTROLÜ</p>
        <h3 class="call-modal__title">
          Bu numara sadece İstanbul Avrupa Yakası servis talepleri içindir.
        </h3>
        <p class="call-modal__desc">Avrupa Yakası dışı aramalar yanıtlanmaz.</p>
        <div class="call-modal__actions">
          <button
            type="button"
            class="call-modal__action call-modal__action--primary w-full"
            data-call-now
            tabindex="-1"
          >
            <div class="flex flex-col items-center">
              <span class="text-sm font-black tracking-tight"
                >BÖLGE ŞARTINI KABUL EDİYORUM</span
              >
              <span
                class="text-[0.65rem] opacity-50 font-medium tracking-normal mt-0.5 mt-0.5 lowercase leading-none"
                >Arama başlatılır</span
              >
            </div>
          </button>
        </div>
        <p
          class="mt-6 text-[10px] text-center text-slate-600 uppercase tracking-[0.2em] font-black"
        >
          BÖLGE FİLTRESİ AKTİF
        </p>
      </div>
    </div>

    <style is:inline>
      .call-modal {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 60;
        transition: opacity 0.25s ease;
      }

      .call-modal.hidden {
        pointer-events: none;
        opacity: 0;
      }

      body.call-modal-open {
        overflow: hidden;
      }

      .call-modal__backdrop {
        position: absolute;
        inset: 0;
        background: rgba(15, 23, 42, 0.75);
        backdrop-filter: blur(6px);
      }

      .call-modal__dialog {
        position: relative;
        width: min(90%, 420px);
        background: linear-gradient(165deg, #0f172a 0%, #1e1b4b 100%);
        border: 2px solid #991b1b;
        border-radius: 28px;
        padding: 36px;
        box-shadow: 0 25px 80px rgba(0, 0, 0, 0.6);
        color: white;
        transform: translateY(16px) scale(0.96);
        opacity: 0;
        transition:
          opacity 0.25s ease,
          transform 0.25s ease;
      }

      .call-modal:not(.hidden) .call-modal__dialog {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      .call-modal__close {
        position: absolute;
        top: 18px;
        right: 18px;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.2);
        font-size: 1.5rem;
        cursor: pointer;
        line-height: 1;
        transition: all 0.2s ease;
      }

      .call-modal__close:hover {
        color: rgba(255, 255, 255, 0.4);
      }

      .call-modal__tag {
        font-size: 0.75rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #ef4444;
        font-weight: 900;
        margin-bottom: 0.75rem;
      }

      .call-modal__title {
        font-family: "Oswald", sans-serif;
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 1rem;
        line-height: 1.25;
        text-transform: uppercase;
      }

      .call-modal__desc {
        color: #cbd5e1;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 2rem;
      }

      .call-modal__actions {
        display: flex;
        gap: 12px;
      }

      .call-modal__action {
        flex: 1;
        text-align: center;
        padding: 1.1rem 1.25rem;
        border-radius: 16px;
        font-weight: 800;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
      }

      .call-modal__action--primary {
        background: #334155;
        color: white;
        border: 2.5px solid #991b1b;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
      }

      .call-modal__action--primary:hover {
        background: #1e293b;
        transform: translateY(-1px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.4);
      }

      @media (max-width: 480px) {
        .call-modal__dialog {
          padding: 24px;
        }

        .call-modal__actions {
          flex-direction: column;
        }
      }
    </style>

    {/* Scroll, Reveal & Call Modal — Vite bundle/minify/cache */}
    <script>
      import '../scripts/reveal.js';
    </script>
    <script>
      import '../scripts/call-modal.js';
    </script>

    {/* Google Analytics — Vite bundle/minify/cache */}
    <script>
      import '../scripts/ga-events.js';
    </script>
  </body>
</html>
