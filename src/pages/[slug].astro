---
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import { getCollection } from "astro:content";
import rehypeSlug from "rehype-slug";
import remarkBreaks from "remark-breaks";
import remarkDirective from "remark-directive";
import BlogCard from "@components/blog/BlogCard.astro";
import ServiceInfoBlocks from "@components/blog/ServiceInfoBlocks.astro";
import TableOfContents from "@components/blog/TableOfContents.tsx";
import { HOWTO_PAGES } from "@/lib/howto-pages";
import { PRICE_RANGES } from "@/lib/service-price-ranges";
import { buildBlogGraph } from "@/lib/schema";
import BlogLayout from "@layouts/BlogLayout.astro";
import remarkCallouts from "@utils/remark-callouts.mjs";
import remarkInternalLinks from "@utils/remark-internal-links.mjs";
import { SITE_CONFIG } from "@utils/constants";
import {
  calculateReadingTime,
  extractFaqsFromHtml,
  findRelatedPosts,
  getBlogFeaturedImage,
  getCategorySlugs,
  isPublishedPost,
} from "@utils/content";

const globalMarkdownProcessor = globalThis as typeof globalThis & {
  __dsgBlogMarkdownProcessor?: ReturnType<typeof createMarkdownProcessor>;
};

const markdownProcessorPromise =
  globalMarkdownProcessor.__dsgBlogMarkdownProcessor ??
  createMarkdownProcessor({
    shikiConfig: {
      theme: "github-dark",
      wrap: true,
    },
    remarkPlugins: [
      remarkBreaks,
      remarkDirective,
      remarkCallouts,
      remarkInternalLinks,
    ],
    rehypePlugins: [rehypeSlug],
  });

globalMarkdownProcessor.__dsgBlogMarkdownProcessor = markdownProcessorPromise;

function wrapFaqSection(html: string) {
  if (!html || html.includes('class="faq-section"')) {
    return html;
  }

  const h2Regex = /<h2[^>]*>([\s\S]*?)<\/h2>/gi;
  let faqHeadingMatch: RegExpExecArray | null = null;

  for (const match of html.matchAll(h2Regex)) {
    const headingText = match[1]
      .replace(/<[^>]+>/g, " ")
      .replace(/\s+/g, " ")
      .trim()
      .toLowerCase();

    if (/s[ıi]k\s*sorulan\s*sorular/u.test(headingText)) {
      faqHeadingMatch = match;
      break;
    }
  }

  if (!faqHeadingMatch || faqHeadingMatch.index === undefined) {
    return html;
  }

  const sectionStart = faqHeadingMatch.index;
  const sectionBodyStart = sectionStart + faqHeadingMatch[0].length;
  const remainingHtml = html.slice(sectionBodyStart);
  const nextH2Match = remainingHtml.match(/<h2[^>]*>/i);
  const sectionEnd =
    nextH2Match?.index !== undefined
      ? sectionBodyStart + nextH2Match.index
      : html.length;

  const faqSection = html.slice(sectionStart, sectionEnd);

  return `${html.slice(0, sectionStart)}<div class="faq-section">${faqSection}</div>${html.slice(sectionEnd)}`;
}

function splitContentHtml(html: string) {
  const tableEndTag = "</table>";
  const tableIdx = html.indexOf(tableEndTag);
  let part1 = html;
  let part2 = "";

  if (tableIdx !== -1) {
    part1 = html.substring(0, tableIdx + tableEndTag.length);
    part2 = html.substring(tableIdx + tableEndTag.length);
    return { part1, part2 };
  }

  const h2Matches = [...html.matchAll(/<h2[^>]*>/gi)];

  if (h2Matches.length >= 3) {
    const splitAt = h2Matches[2].index;

    if (splitAt !== undefined) {
      part1 = html.substring(0, splitAt);
      part2 = html.substring(splitAt);
    }
  }

  return { part1, part2 };
}

export async function getStaticPaths() {
  const publishedPosts = await getCollection("blog", ({ data }) =>
    isPublishedPost(data),
  );

  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const scheduledPosts = allPosts.filter((post) => {
    const publishDate =
      post.data.publishDate instanceof Date
        ? post.data.publishDate
        : new Date(post.data.publishDate);

    return publishDate > new Date();
  });

  const categorySlugs = new Set(getCategorySlugs());

  const publishedRoutes = publishedPosts
    .filter((post) => !categorySlugs.has(post.slug))
    .map((post) => ({
      params: { slug: post.slug },
      props: { post, isPublished: true },
    }));

  const scheduledRoutes = scheduledPosts
    .filter((post) => !categorySlugs.has(post.slug))
    .map((post) => ({
      params: { slug: post.slug },
      props: { post, isPublished: false },
    }));

  return [...publishedRoutes, ...scheduledRoutes];
}

const { slug } = Astro.params;
const { post, isPublished } = Astro.props || {};

if (slug && getCategorySlugs().includes(slug.toLowerCase())) {
  return Astro.redirect(`/${slug.toLowerCase()}`, 301);
}

if (!post) {
  return Astro.redirect("/blog", 404);
}

const data = post.data;
const markdownProcessor = await markdownProcessorPromise;

const { code: renderedHtml, metadata } = await markdownProcessor.render(
  post.body,
  {
    frontmatter: data,
  },
);

const publishDate =
  data.publishDate instanceof Date
    ? data.publishDate
    : new Date(data.publishDate);
const updatedDate =
  data.updatedDate instanceof Date
    ? data.updatedDate
    : data.updatedDate
      ? new Date(data.updatedDate)
      : publishDate;
const actuallyPublished = isPublishedPost(data);

const allPostsForRelated = await getCollection("blog", ({ data }) => !data.draft);
const publishedPostsForRelated = allPostsForRelated.filter((entry) =>
  isPublishedPost(entry.data),
);
const relatedPosts = findRelatedPosts(post, publishedPostsForRelated, 3);

const html = wrapFaqSection(renderedHtml);
const { part1, part2 } = splitContentHtml(html);
const extractedFaqs = extractFaqsFromHtml(html);
const readingTime = data.readingTime || calculateReadingTime(html);
const heroImage = getBlogFeaturedImage(post);
const heroDisplayImage = heroImage.endsWith(".jpg")
  ? heroImage.replace(".jpg", "-1280.webp")
  : heroImage;
const sectionCount =
  metadata.headings?.filter((heading) => heading.depth === 2).length ||
  [...html.matchAll(/<h2[^>]*>/gi)].length;
const formattedDate = publishDate.toLocaleDateString("tr-TR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const formattedUpdatedDate = updatedDate.toLocaleDateString("tr-TR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const howtoData = HOWTO_PAGES[post.slug];
const priceRange = PRICE_RANGES[post.slug];
const descriptionText = data.description || "";
const graphSchema = buildBlogGraph({
  slug: post.slug,
  title: data.title,
  description: descriptionText,
  image: heroImage,
  datePublished: publishDate.toISOString(),
  dateModified: updatedDate.toISOString(),
  author: {
    name: data.author || "DSG Teknik Ekip",
    jobTitle: "DSG Şanzıman Uzmanı",
    url: "https://dsgservisi.com/hakkimizda",
  },
  serviceAreas: [
    "Beylikdüzü",
    "Esenyurt",
    "Avcılar",
    "Küçükçekmece",
    "Büyükçekmece",
    "Bakırköy",
    "İstanbul",
  ],
  faqItems: extractedFaqs,
  howtoData,
  priceRange,
});
---

<BlogLayout post={post} isPublished={actuallyPublished}>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(graphSchema)}
  />

  <article class="bg-transparent">
    <header class="relative isolate overflow-hidden bg-slate-900 text-white min-h-[420px] flex items-end">
      <div class="absolute inset-0">
        <img
          src={heroDisplayImage}
          alt={data.imageAlt || data.title}
          class="w-full h-full object-cover opacity-40"
          loading="eager"
          width="1200"
          height="630"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/70 to-slate-900/30" />
      </div>

      <div class="relative z-10 w-full px-4 pb-10 pt-24 max-w-5xl mx-auto sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-center gap-3 mb-5">
          {
            data.category && (
              <div class="inline-flex items-center gap-2 bg-amber-500/15 border border-amber-500/25 text-amber-400 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider">
                {data.category}
              </div>
            )
          }

          <div class="flex flex-wrap gap-3 text-xs font-semibold uppercase tracking-wider text-white/60">
            <span>{formattedDate}</span>
            <span>{readingTime} dk okuma</span>
            <span>{sectionCount} bölüm</span>
          </div>
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-4">
          {data.title}
        </h1>

        {
          descriptionText && (
            <p class="max-w-3xl text-base sm:text-lg leading-relaxed text-white/75">
              {descriptionText}
            </p>
          )
        }
      </div>
    </header>

    <section class="max-w-7xl mx-auto px-4 pb-2 sm:px-6 lg:px-8">
      <ServiceInfoBlocks slug={post.slug} />
    </section>

    <div class="max-w-7xl mx-auto px-4 py-10 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_280px] gap-10">
        <div class="min-w-0" id="blog-content-column">
          <div class="lg:hidden mb-6">
            <TableOfContents client:idle contentId="article-content" />
          </div>

          <div class="overflow-hidden rounded-2xl border border-white/10 mb-8 shadow-xl">
            <img
              src={heroDisplayImage}
              alt={data.imageAlt || data.title}
              class="w-full h-auto object-cover max-h-[420px]"
              loading="eager"
              width="1200"
              height="630"
              decoding="async"
            />
          </div>

          <div id="article-content">
            <div class="prose prose-lg w-full max-w-none" set:html={part1} />

            <div class="my-8 p-6 rounded-2xl bg-amber-500/10 border border-amber-500/20 text-center">
              <p class="text-white font-semibold mb-4">
                Aracınızın durumu hakkında ücretsiz değerlendirme alın
              </p>
              <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a
                  href={`tel:${SITE_CONFIG.phoneTel}`}
                  class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-amber-500 text-slate-950 font-bold hover:bg-amber-400 transition-colors"
                >
                  Hemen Ara
                </a>
                <a
                  href="/iletisim"
                  class="inline-flex items-center justify-center px-6 py-3 rounded-xl border border-white/20 text-white hover:bg-white/10 transition-colors"
                >
                  Randevu Al
                </a>
              </div>
            </div>

            {
              part2 && (
                <div class="prose prose-lg w-full max-w-none" set:html={part2} />
              )
            }
          </div>

          <div class="mt-8 pt-6 border-t border-white/10 text-center">
            <div class="text-xs font-bold uppercase tracking-wider text-slate-500">
              Son güncelleme: {formattedUpdatedDate}
            </div>

            {
              data.tags && data.tags.length > 0 && (
                <div class="mt-4 flex flex-wrap items-center justify-center gap-2">
                  {data.tags.map((tag) => (
                    <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] font-semibold uppercase tracking-wider text-slate-300">
                      {tag}
                    </span>
                  ))}
                </div>
              )
            }
          </div>
        </div>

        <div class="hidden lg:block">
          <div class="sticky top-6">
            <TableOfContents client:idle contentId="article-content" />
          </div>
        </div>
      </div>
    </div>
  </article>

  {
    relatedPosts.length > 0 && (
      <section class="bg-[#0f172a] border-t border-white/10 relative z-10">
        <div class="max-w-7xl mx-auto px-4 py-16 sm:px-6 lg:px-8">
          <div class="flex items-center gap-3 mb-10">
            <span class="w-1 h-8 bg-amber-500 rounded-full" />
            <h2 class="font-display font-bold text-white text-2xl md:text-3xl">
              İlgili Yazılar
            </h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedPosts.map((relatedPost, index) => (
              <BlogCard post={relatedPost} index={index} size="rect-regular" />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="section relative overflow-hidden py-24 border-t border-white/5">
    <div class="absolute inset-0 bg-gradient-to-b from-slate-900 to-black pointer-events-none" />

    <div class="container max-w-4xl relative z-10 text-center">
      <div class="inline-block p-3 rounded-full bg-amber-500/10 mb-6 border border-amber-500/20">
        <svg
          class="w-8 h-8 text-amber-500"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M13 10V3L4 14h7v7l9-11h-7z"
          />
        </svg>
      </div>

      <h2 class="font-display font-bold mb-6 text-3xl md:text-5xl text-white">
        Profesyonel <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-amber-600">DSG Servis</span>
        Hizmeti
      </h2>

      <p class="text-xl text-slate-400 mb-10 leading-relaxed max-w-2xl mx-auto">
        DSG şanzıman ve mekatronik konusunda uzman ekibimizle tanışın. 15 yıllık
        deneyim ve 6500+ mutlu müşteri ile güvenilir çözümler.
      </p>

      <div class="flex flex-col sm:flex-row gap-6 justify-center w-full max-w-2xl mx-auto sm:max-w-none items-center">
        <a
          href="/iletisim"
          class="w-full sm:w-64 inline-flex items-center justify-center px-8 py-5 rounded-xl bg-amber-500 text-slate-950 text-xl font-bold shadow-[0_0_20px_rgba(245,158,11,0.3)] hover:shadow-[0_0_35px_rgba(245,158,11,0.6)] hover:bg-amber-400 hover:-translate-y-1 transition-all duration-300 border-none whitespace-nowrap"
        >
          Randevu Alın
        </a>
        <a
          href="/hizmetlerimiz"
          class="w-full sm:w-64 inline-flex items-center justify-center px-8 py-5 rounded-xl bg-transparent border-2 border-white/30 text-white text-xl font-bold hover:bg-white hover:text-slate-900 hover:border-white hover:-translate-y-1 transition-all duration-300 whitespace-nowrap backdrop-blur-sm"
          style="background-color: transparent !important; border-color: rgba(255,255,255,0.3) !important; color: white !important;"
        >
          Hizmetlerimiz
        </a>
      </div>
    </div>
  </section>
</BlogLayout>
